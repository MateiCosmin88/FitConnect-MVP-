# Copy this file to `.env` and fill in real values.
# Never commit the real .env.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False

# Add your LXC IP and any DNS name that points at it.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.168.0.42,fitconnect.local

# For CSRF over http on your LAN, add scheme://host entries.
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.0.42,http://fitconnect.local

# Optional: keep the SQLite file inside the mounted volume (recommended).
DJANGO_DB_PATH=/app/data/db.sqlite3

# Email backend (console keeps things simple; switch to SMTP later).
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@fitconnect.local

# Set to true once you put the site behind HTTPS.
DJANGO_SECURE_COOKIES=false
